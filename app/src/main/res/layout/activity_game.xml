<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginStart="40dp"
    android:padding="12dp"
    android:background="#1A1A2E">

    <!-- ── Status bar ── -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/status_not_connected"
        android:textColor="#E0E0E0"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:padding="6dp"
        android:background="#16213E"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Player name input ── -->
    <EditText
        android:id="@+id/et_player_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="@string/hint_player_name"
        android:text="@string/default_player_name"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:backgroundTint="#E040FB"
        android:padding="8dp"
        android:inputType="text"
        android:autofillHints="username"
        app:layout_constraintTop_toBottomOf="@id/tv_status"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_connect"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp" />

    <!-- ── Connect button ── -->
    <Button
        android:id="@+id/btn_connect"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_connect"
        android:backgroundTint="#E040FB"
        app:layout_constraintTop_toBottomOf="@id/tv_status"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- ── Game ID input ── -->
    <EditText
        android:id="@+id/et_game_id"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="@string/hint_game_id"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:backgroundTint="#E040FB"
        android:padding="8dp"
        android:inputType="text"
        android:autofillHints="no"
        app:layout_constraintTop_toBottomOf="@id/et_player_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- ── Action dropdown label ── -->
    <TextView
        android:id="@+id/tv_action_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_action"
        android:textColor="#CCCCCC"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/et_game_id"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="12dp" />

    <!-- ── Spinner (dropdown) ── -->
    <Spinner
        android:id="@+id/spinner_action"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:backgroundTint="#E040FB"
        android:popupBackground="#16213E"
        app:layout_constraintTop_toBottomOf="@id/tv_action_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_send"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="8dp" />

    <!-- ── Send button ── -->
    <Button
        android:id="@+id/btn_send"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_send"
        android:backgroundTint="#E040FB"
        app:layout_constraintTop_toBottomOf="@id/tv_action_label"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp" />

    <!-- ── Clear button ── -->
    <Button
        android:id="@+id/btn_clear"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_clear"
        android:textSize="12sp"
        android:backgroundTint="#444466"
        app:layout_constraintTop_toBottomOf="@id/spinner_action"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="6dp" />


    <Button
        android:id="@+id/button_gameboard"
        android:enabled="false"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/gameboard"
        android:backgroundTint="#E040FB"
        app:layout_constraintTop_toBottomOf="@id/spinner_action"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="6dp" />


    <!-- ── Event log label ── -->
    <TextView
        android:id="@+id/tv_event_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_events"
        android:textColor="#CCCCCC"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/button_gameboard"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp" />

    <!-- ── Scrollable JSON output ── -->
    <ScrollView
        android:id="@+id/scroll_events"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#0D0D1A"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_event_label"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/tv_event_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#A8FF78"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.3" />
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
