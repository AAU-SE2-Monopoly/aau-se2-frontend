<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">
        <!-- Main Menu – launcher -->
        <activity
            android:name="at.aau.monopoly.klagenfurt.MainMenuActivity"
            android:exported="true"
            android:label="Monopoly Klagenfurt"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.MyApplication.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Credits -->
        <activity
            android:name="at.aau.monopoly.klagenfurt.CreditsActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.MyApplication" />

        <activity
            android:name="at.aau.monopoly.klagenfurt.ui.GameboardUI"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.MyApplication" />

        <activity
            android:name="at.aau.monopoly.klagenfurt.GameActivity"
            android:exported="false"
            android:label="Monopoly Debug"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.MyApplication" />

        <!-- Lobby – game browser -->
        <activity
            android:name="at.aau.monopoly.klagenfurt.LobbyActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.MyApplication" />

        <!-- Join – name & icon picker -->
        <activity
            android:name="at.aau.monopoly.klagenfurt.JoinActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.MyApplication" />
    </application>

</manifest>